<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HealthHabitApp.ViewModels"
             x:Class="HealthHabitApp.Views.SettingsPage"
             Title=""
             BackgroundColor="{StaticResource PageBackground}">

    <ContentPage.BindingContext>
        <vm:SettingsViewModel />
    </ContentPage.BindingContext>

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- Header -->
            <Grid BackgroundColor="{StaticResource Primary}"
                  Padding="20,50,20,28">
                <VerticalStackLayout Spacing="4">
                    <Label Text="Settings"
                           FontSize="26" FontAttributes="Bold"
                           TextColor="White"
                           FontFamily="OpenSansSemibold"/>
                    <Label Text="Customize your experience"
                           FontSize="13"
                           TextColor="#CCFFD6"/>
                </VerticalStackLayout>
            </Grid>

            <VerticalStackLayout Padding="16,20,16,0" Spacing="16">

                <!-- Notifications Section -->
                <Label Text="NOTIFICATIONS"
                       FontSize="12" FontAttributes="Bold"
                       TextColor="{StaticResource TextMuted}"
                       Margin="4,0,0,0"
                       CharacterSpacing="1.5"/>

                <Border BackgroundColor="{StaticResource CardBackground}"
                        StrokeThickness="1" Stroke="{StaticResource BorderColor}"
                        StrokeShape="RoundRectangle 16"
                        Padding="0">
                    <VerticalStackLayout>
                        <!-- Notifications Toggle -->
                        <Grid Padding="16,14" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" BackgroundColor="{StaticResource PrimaryLight}"
                                    StrokeThickness="0" StrokeShape="Ellipse" WidthRequest="36" HeightRequest="36">
                                <Label Text="🔔" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text="Enable Notifications" FontSize="15" FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" FontFamily="OpenSansSemibold"/>
                                <Label Text="Get daily habit reminders" FontSize="12" TextColor="{StaticResource TextMuted}"/>
                            </VerticalStackLayout>
                            <Switch Grid.Column="2" IsToggled="{Binding NotificationsEnabled}"
                                    OnColor="{StaticResource Primary}" VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="{StaticResource DividerColor}" Margin="16,0"/>

                        <!-- Sound Toggle -->
                        <Grid Padding="16,14" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" BackgroundColor="#FFF0EA"
                                    StrokeThickness="0" StrokeShape="Ellipse" WidthRequest="36" HeightRequest="36">
                                <Label Text="🔊" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text="Sound" FontSize="15" FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" FontFamily="OpenSansSemibold"/>
                                <Label Text="Play sound with notifications" FontSize="12" TextColor="{StaticResource TextMuted}"/>
                            </VerticalStackLayout>
                            <Switch Grid.Column="2" IsToggled="{Binding SoundEnabled}"
                                    OnColor="{StaticResource Primary}" VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="{StaticResource DividerColor}" Margin="16,0"/>

                        <!-- Request Permission -->
                        <Grid Padding="16,14" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" BackgroundColor="{StaticResource SurfaceColor}"
                                    StrokeThickness="0" StrokeShape="Ellipse" WidthRequest="36" HeightRequest="36">
                                <Label Text="🔑" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text="Request Permission" FontSize="15" FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" FontFamily="OpenSansSemibold"/>
                                <Label Text="Grant notification access" FontSize="12" TextColor="{StaticResource TextMuted}"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›" FontSize="20"
                                   TextColor="{StaticResource TextMuted}" VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding RequestNotificationPermissionsCommand}"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Appearance Section -->
                <Label Text="APPEARANCE"
                       FontSize="12" FontAttributes="Bold"
                       TextColor="{StaticResource TextMuted}"
                       Margin="4,4,0,0"
                       CharacterSpacing="1.5"/>

                <Border BackgroundColor="{StaticResource CardBackground}"
                        StrokeThickness="1" Stroke="{StaticResource BorderColor}"
                        StrokeShape="RoundRectangle 16" Padding="0">
                    <Grid Padding="16,14" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" BackgroundColor="#EEE8FF"
                                StrokeThickness="0" StrokeShape="Ellipse" WidthRequest="36" HeightRequest="36">
                            <Label Text="🌙" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="Dark Mode" FontSize="15" FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}" FontFamily="OpenSansSemibold"/>
                            <Label Text="Coming soon" FontSize="12" TextColor="{StaticResource TextMuted}"/>
                        </VerticalStackLayout>
                        <Switch Grid.Column="2" IsToggled="{Binding DarkModeEnabled}"
                                OnColor="{StaticResource Primary}" VerticalOptions="Center"
                                IsEnabled="False"/>
                    </Grid>
                </Border>

                <!-- Data Section -->
                <Label Text="DATA"
                       FontSize="12" FontAttributes="Bold"
                       TextColor="{StaticResource TextMuted}"
                       Margin="4,4,0,0"
                       CharacterSpacing="1.5"/>

                <Border BackgroundColor="{StaticResource CardBackground}"
                        StrokeThickness="1" Stroke="{StaticResource BorderColor}"
                        StrokeShape="RoundRectangle 16" Padding="0">
                    <VerticalStackLayout>
                        <Grid Padding="16,14" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" BackgroundColor="#FEE2E2"
                                    StrokeThickness="0" StrokeShape="Ellipse" WidthRequest="36" HeightRequest="36">
                                <Label Text="🗑️" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text="Clear All Data" FontSize="15" FontAttributes="Bold"
                                       TextColor="#EF4444" FontFamily="OpenSansSemibold"/>
                                <Label Text="Delete all habits and history" FontSize="12" TextColor="{StaticResource TextMuted}"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›" FontSize="20"
                                   TextColor="{StaticResource TextMuted}" VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ClearAllDataCommand}"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- About Section -->
                <Label Text="ABOUT"
                       FontSize="12" FontAttributes="Bold"
                       TextColor="{StaticResource TextMuted}"
                       Margin="4,4,0,0"
                       CharacterSpacing="1.5"/>

                <Border BackgroundColor="{StaticResource CardBackground}"
                        StrokeThickness="1" Stroke="{StaticResource BorderColor}"
                        StrokeShape="RoundRectangle 16" Padding="0">
                    <VerticalStackLayout>
                        <Grid Padding="16,14" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" BackgroundColor="{StaticResource PrimaryLight}"
                                    StrokeThickness="0" StrokeShape="Ellipse" WidthRequest="36" HeightRequest="36">
                                <Label Text="💬" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text="Send Feedback" FontSize="15" FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" FontFamily="OpenSansSemibold"/>
                                <Label Text="Help us improve the app" FontSize="12" TextColor="{StaticResource TextMuted}"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›" FontSize="20"
                                   TextColor="{StaticResource TextMuted}" VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SendFeedbackCommand}"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>

                        <BoxView HeightRequest="1" Color="{StaticResource DividerColor}" Margin="16,0"/>

                        <Grid Padding="16,14" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" BackgroundColor="#FFF0EA"
                                    StrokeThickness="0" StrokeShape="Ellipse" WidthRequest="36" HeightRequest="36">
                                <Label Text="⭐" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text="Rate the App" FontSize="15" FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" FontFamily="OpenSansSemibold"/>
                                <Label Text="Share your experience" FontSize="12" TextColor="{StaticResource TextMuted}"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›" FontSize="20"
                                   TextColor="{StaticResource TextMuted}" VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding RateAppCommand}"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>

                        <BoxView HeightRequest="1" Color="{StaticResource DividerColor}" Margin="16,0"/>

                        <Grid Padding="16,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Label Text="App Version" FontSize="15"
                                   TextColor="{StaticResource TextSecondary}"/>
                            <Label Grid.Column="1" Text="{Binding AppVersion}"
                                   FontSize="15" TextColor="{StaticResource TextMuted}"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- App branding footer -->
                <VerticalStackLayout HorizontalOptions="Center" Spacing="4" Margin="0,8,0,40">
                    <Label Text="🌿 HealthHabitApp"
                           FontSize="16" FontAttributes="Bold"
                           TextColor="{StaticResource Primary}"
                           HorizontalOptions="Center"
                           FontFamily="OpenSansSemibold"/>
                    <Label Text="Build better habits, one day at a time."
                           FontSize="12"
                           TextColor="{StaticResource TextMuted}"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
