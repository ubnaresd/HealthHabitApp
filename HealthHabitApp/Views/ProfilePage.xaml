<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HealthHabitApp.ViewModels"
             x:Class="HealthHabitApp.Views.ProfilePage"
             Title=""
             BackgroundColor="{StaticResource PageBackground}">

    <ContentPage.BindingContext>
        <vm:ProfileViewModel />
    </ContentPage.BindingContext>

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- Header with Avatar -->
            <Grid BackgroundColor="{StaticResource Primary}"
                  Padding="20,50,20,36">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Label Grid.Row="0"
                       Text="Profile"
                       FontSize="26" FontAttributes="Bold"
                       TextColor="White"
                       FontFamily="OpenSansSemibold"/>

                <!-- Avatar & Name -->
                <HorizontalStackLayout Grid.Row="2" Spacing="16" VerticalOptions="Center">
                    <!-- Avatar Circle -->
                    <Border BackgroundColor="#17A849"
                            StrokeThickness="3" Stroke="White"
                            StrokeShape="Ellipse"
                            WidthRequest="70" HeightRequest="70">
                        <Label Text="{Binding AvatarInitial}"
                               FontSize="28" FontAttributes="Bold"
                               TextColor="White"
                               HorizontalOptions="Center" VerticalOptions="Center"
                               FontFamily="OpenSansSemibold"/>
                    </Border>

                    <VerticalStackLayout Spacing="4" VerticalOptions="Center">
                        <Label Text="{Binding UserName}"
                               FontSize="22" FontAttributes="Bold"
                               TextColor="White"
                               FontFamily="OpenSansSemibold"/>
                        <Label Text="{Binding MemberSinceText, StringFormat='Member since {0}'}"
                               FontSize="13"
                               TextColor="#CCFFD6"/>
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </Grid>

            <!-- Stats Cards Row -->
            <Grid Padding="16,16,16,0" ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        BackgroundColor="{StaticResource CardBackground}"
                        StrokeThickness="1" Stroke="{StaticResource BorderColor}"
                        StrokeShape="RoundRectangle 14" Padding="10,14">
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                        <Label Text="{Binding TotalHabits}"
                               FontSize="24" FontAttributes="Bold"
                               TextColor="{StaticResource Primary}"
                               HorizontalOptions="Center"
                               FontFamily="OpenSansSemibold"/>
                        <Label Text="Habits" FontSize="11" TextColor="{StaticResource TextMuted}" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1"
                        BackgroundColor="{StaticResource CardBackground}"
                        StrokeThickness="1" Stroke="{StaticResource BorderColor}"
                        StrokeShape="RoundRectangle 14" Padding="10,14">
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                        <HorizontalStackLayout HorizontalOptions="Center">
                            <Label Text="🔥" FontSize="16"/>
                            <Label Text="{Binding CurrentStreak}"
                                   FontSize="24" FontAttributes="Bold"
                                   TextColor="{StaticResource StreakColor}"
                                   FontFamily="OpenSansSemibold"/>
                        </HorizontalStackLayout>
                        <Label Text="Streak" FontSize="11" TextColor="{StaticResource TextMuted}" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="2"
                        BackgroundColor="{StaticResource CardBackground}"
                        StrokeThickness="1" Stroke="{StaticResource BorderColor}"
                        StrokeShape="RoundRectangle 14" Padding="10,14">
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                        <Label Text="{Binding LongestStreak}"
                               FontSize="24" FontAttributes="Bold"
                               TextColor="{StaticResource Accent}"
                               HorizontalOptions="Center"
                               FontFamily="OpenSansSemibold"/>
                        <Label Text="Best" FontSize="11" TextColor="{StaticResource TextMuted}" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Daily Goal Card -->
            <Border BackgroundColor="{StaticResource CardBackground}"
                    StrokeThickness="1" Stroke="{StaticResource BorderColor}"
                    StrokeShape="RoundRectangle 16"
                    Margin="16,16,16,0" Padding="16,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Daily Habit Goal"
                               FontSize="15" FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"
                               FontFamily="OpenSansSemibold"/>
                        <Label Text="{Binding DailyGoal, StringFormat='{0} habits per day'}"
                               FontSize="13" TextColor="{StaticResource TextSecondary}"/>
                    </VerticalStackLayout>
                    <Border Grid.Column="1"
                            BackgroundColor="{StaticResource PrimaryLight}"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 20"
                            Padding="14,8">
                        <Label Text="{Binding DailyGoal, StringFormat='🎯 {0}'}"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource Primary}"
                               FontFamily="OpenSansSemibold"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Edit Profile Card (view mode) -->
            <Border BackgroundColor="{StaticResource CardBackground}"
                    StrokeThickness="1" Stroke="{StaticResource BorderColor}"
                    StrokeShape="RoundRectangle 16"
                    Margin="16,12,16,0" Padding="16,14"
                    IsVisible="{Binding IsEditing, Converter={x:StaticResource InverseBoolConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <VerticalStackLayout Spacing="2">
                        <Label Text="Edit Profile"
                               FontSize="15" FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"
                               FontFamily="OpenSansSemibold"/>
                        <Label Text="Update your name and daily goal"
                               FontSize="13" TextColor="{StaticResource TextSecondary}"/>
                    </VerticalStackLayout>
                    <Border Grid.Column="1"
                            BackgroundColor="{StaticResource SurfaceColor}"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 20"
                            Padding="14,8">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding StartEditingCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="Edit ✏️" FontSize="13"
                               TextColor="{StaticResource TextPrimary}"
                               FontFamily="OpenSansSemibold"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Edit Form (edit mode) -->
            <Border BackgroundColor="{StaticResource CardBackground}"
                    StrokeThickness="2" Stroke="{StaticResource Primary}"
                    StrokeShape="RoundRectangle 16"
                    Margin="16,12,16,0" Padding="16,14"
                    IsVisible="{Binding IsEditing}">
                <VerticalStackLayout Spacing="14">
                    <Label Text="Edit Profile"
                           FontSize="15" FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}"
                           FontFamily="OpenSansSemibold"/>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Your Name" FontSize="12" TextColor="{StaticResource TextSecondary}"/>
                        <Border BackgroundColor="{StaticResource SurfaceColor}"
                                StrokeThickness="1" Stroke="{StaticResource BorderColor}"
                                StrokeShape="RoundRectangle 10" Padding="12,10">
                            <Entry Text="{Binding EditUserName}"
                                   FontSize="15"
                                   TextColor="{StaticResource TextPrimary}"
                                   BackgroundColor="Transparent"/>
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Daily Goal" FontSize="12" TextColor="{StaticResource TextSecondary}"/>
                        <Border BackgroundColor="{StaticResource SurfaceColor}"
                                StrokeThickness="1" Stroke="{StaticResource BorderColor}"
                                StrokeShape="RoundRectangle 10" Padding="12,10">
                            <Entry Text="{Binding EditDailyGoal}"
                                   Keyboard="Numeric"
                                   FontSize="15"
                                   TextColor="{StaticResource TextPrimary}"
                                   BackgroundColor="Transparent"/>
                        </Border>
                    </VerticalStackLayout>

                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                BackgroundColor="{StaticResource SurfaceColor}"
                                StrokeThickness="0" StrokeShape="RoundRectangle 10" Padding="0,12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding CancelEditCommand}"/>
                            </Border.GestureRecognizers>
                            <Label Text="Cancel" FontSize="14" TextColor="{StaticResource TextSecondary}"
                                   HorizontalOptions="Center" FontFamily="OpenSansSemibold"/>
                        </Border>

                        <Border Grid.Column="1"
                                BackgroundColor="{StaticResource Primary}"
                                StrokeThickness="0" StrokeShape="RoundRectangle 10" Padding="0,12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SaveProfileCommand}"/>
                            </Border.GestureRecognizers>
                            <Label Text="Save" FontSize="14" TextColor="White"
                                   HorizontalOptions="Center" FontFamily="OpenSansSemibold"/>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <BoxView HeightRequest="80" Color="Transparent"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
