<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Brand Colors -->
    <Color x:Key="Primary">#1DB954</Color>
    <Color x:Key="PrimaryDark">#17A849</Color>
    <Color x:Key="PrimaryLight">#E8F8EF</Color>
    <Color x:Key="Accent">#FF6B35</Color>
    <Color x:Key="AccentLight">#FFF0EA</Color>

    <!-- Backgrounds -->
    <Color x:Key="PageBackground">#F7F9FC</Color>
    <Color x:Key="CardBackground">#FFFFFF</Color>
    <Color x:Key="SurfaceColor">#F0F4F8</Color>

    <!-- Text -->
    <Color x:Key="TextPrimary">#1A1F2E</Color>
    <Color x:Key="TextSecondary">#6B7280</Color>
    <Color x:Key="TextMuted">#9CA3AF</Color>
    <Color x:Key="TextOnPrimary">#FFFFFF</Color>

    <!-- Status -->
    <Color x:Key="StreakColor">#FF6B35</Color>
    <Color x:Key="CompletedColor">#1DB954</Color>
    <Color x:Key="PendingColor">#E5E7EB</Color>
    <Color x:Key="WarningColor">#F59E0B</Color>

    <!-- Borders -->
    <Color x:Key="BorderColor">#E5E7EB</Color>
    <Color x:Key="DividerColor">#F3F4F6</Color>

    <!-- Legacy -->
    <Color x:Key="PrimaryDark2">#17A849</Color>
    <Color x:Key="PrimaryDarkText">#1A1F2E</Color>
    <Color x:Key="Secondary">#E8F8EF</Color>
    <Color x:Key="SecondaryDarkText">#1DB954</Color>
    <Color x:Key="Tertiary">#FF6B35</Color>
    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Magenta">#D600AA</Color>
    <Color x:Key="MidnightBlue">#190649</Color>
    <Color x:Key="OffBlack">#1f1f1f</Color>
    <Color x:Key="Gray100">#F3F4F6</Color>
    <Color x:Key="Gray200">#E5E7EB</Color>
    <Color x:Key="Gray300">#D1D5DB</Color>
    <Color x:Key="Gray400">#9CA3AF</Color>
    <Color x:Key="Gray500">#6B7280</Color>
    <Color x:Key="Gray600">#4B5563</Color>
    <Color x:Key="Gray900">#111827</Color>
    <Color x:Key="Gray950">#030712</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>
    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>

</ResourceDictionary>
